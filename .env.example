# ==================== Database Configuration ====================
# PostgreSQL
POSTGRES_DB=taskiu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_PORT=5433

# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_this_mongo_password
MONGO_PORT=27017

# Mongo Express (管理工具)
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=change_this_admin_password

# ==================== Cache & Message Queue ====================
# Redis
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_this_rabbitmq_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ==================== Object Storage ====================
# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_this_minio_password_min_8_chars
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==================== Application Configuration ====================
# Spring Boot
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8088

# JWT (使用 openssl rand -base64 32 生成)
JWT_SECRET=change_this_to_a_very_long_random_string_minimum_256_bits
JWT_EXPIRATION=86400000

# Mail (可選，如果不需要郵件功能可以留空)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ==================== Network & Proxy ====================
# Nginx
NGINX_PORT=80

# Cloudflare Tunnel Token
# 從 Cloudflare Zero Trust Dashboard 獲取
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ==================== Environment ====================
ENVIRONMENT=production
